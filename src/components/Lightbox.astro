---
// 画像拡大モーダル。ギャラリーを使うページで1回読み込む。
// View Transitions 後も動くよう、クリックは document へのイベント委譲で拾い、
// 要素参照はクリック時に毎回取得する（ページ差し替えで参照が死ぬのを防ぐ）。
---
<div id="lightbox" class="lightbox">
  <div class="lb-close hover-target">CLOSE</div>
  <div class="lb-content">
    <div class="lb-img-wrap">
      <img id="lb-img" class="lb-img" src="" alt="" />
    </div>
    <div class="lb-info">
      <h3 id="lb-title" class="lb-title"></h3>
      <p id="lb-desc" class="lb-desc"></p>
    </div>
  </div>
</div>

<script>
  const getEls = () => {
    const lb = document.getElementById('lightbox');
    const img = document.getElementById('lb-img') as HTMLImageElement | null;
    const title = document.getElementById('lb-title');
    const desc = document.getElementById('lb-desc');
    return lb && img && title && desc ? { lb, img, title, desc } : null;
  };

  (window as any).openLightbox = (src: string, title?: string, desc?: string) => {
    const els = getEls();
    if (!els) return;
    els.img.src = src;
    if (title && desc) {
      els.lb.classList.add('has-text');
      els.title.textContent = title;
      els.desc.textContent = desc;
    } else {
      els.lb.classList.remove('has-text');
      els.title.textContent = '';
      els.desc.textContent = '';
    }
    els.lb.classList.add('active');
  };

  const closeLightbox = () => {
    const els = getEls();
    if (!els) return;
    els.lb.classList.remove('active');
    setTimeout(() => {
      els.img.src = '';
      els.lb.classList.remove('has-text');
    }, 400);
  };

  // モジュールは1回しか実行されないため、多重バインドの心配なく document に委譲する
  document.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    const trigger = t.closest<HTMLElement>('[data-lightbox]');
    if (trigger) {
      (window as any).openLightbox(
        trigger.dataset.img,
        trigger.dataset.title || undefined,
        trigger.dataset.desc || undefined
      );
      return;
    }
    if (t.closest('#lightbox')) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>
